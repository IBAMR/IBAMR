test {
   f_data_type  = "CELL"
   n_components = 1
   ghost_width  = 1

   asm_subdomain_construction_mode = "COUPLING_AWARE"
   coupling_aware_asm_closure_policy = "STRICT"
   subdomain_box_size = 1, 1
   subdomain_overlap_size = 0, 0
   coupling_aware_asm_seed_axis = 0
   coupling_aware_asm_seed_stride = 1

   compare_against_mode = TRUE
   compare_asm_subdomain_construction_mode = "GEOMETRICAL"
   compare_coupling_aware_asm_closure_policy = "RELAXED"
   compare_subdomain_box_size = 1, 1
   compare_subdomain_overlap_size = 0, 0
   compare_coupling_aware_asm_seed_axis = 0
   compare_coupling_aware_asm_seed_stride = 1
}

Main {
   log_file_name               = "stokes_petsc_level_solver_asm_modes.ca.strict_equals_geom_vanka.log"
   log_all_nodes               = FALSE
   viz_writer                  = "VisIt"
   viz_dump_dirname            = "viz2d"
   visit_number_procs_per_file = 1
}

N = 8

CartesianGeometry {
   domain_boxes       = [(0, 0), (N - 1, N - 1)]
   x_lo               = 0.0, 0.0
   x_up               = 1.0, 1.0
   periodic_dimension = 1, 1
}

GriddingAlgorithm {
   max_levels = 1
   ratio_to_coarser { level_1 = 2, 2 }
   largest_patch_size { level_0 = N, N }
   smallest_patch_size { level_0 = N, N }
}

StandardTagAndInitialize {
   tagging_method = "REFINE_BOXES"
   RefineBoxes { level_0 = [(0, 0), (N - 1, N - 1)] }
}

LoadBalancer {
   bin_pack_method = "SPATIAL"
   max_workload_factor = 1
}
