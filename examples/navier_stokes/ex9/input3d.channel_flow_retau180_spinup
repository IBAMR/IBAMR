// 3D plane-channel spin-up case targeting approximately Re_tau = 180.
//
// With LY = 2, the channel half-height is delta = 1. Using the constant
// streamwise body force below gives an equilibrium estimate
// u_tau = sqrt(f_x * delta) = sqrt(0.02) ~= 0.1414, so with nu = MU/RHO =
// 7.5e-4 we get Re_tau ~= 188.6. This is intended as a practical verification
// target near the standard low-Re channel benchmark regime.
//
// This file is the spin-up phase. Run it first, then restart from one of its
// restart dumps with input3d.channel_flow_retau180_average.

MU  = 7.5e-4
RHO = 1.0
LX  = 6.283185307179586
LY  = 2.0
LZ  = 3.141592653589793

MAX_LEVELS = 1
REF_RATIO  = 2
NX = 128
NY = 96
NZ = 96

SOLVER_TYPE        = "STAGGERED"
CFL_MAX            = 0.25
DT_MAX             = 5.0e-4
START_TIME         = 0.0
END_TIME           = 20.0
GROW_DT            = 1.0
NUM_CYCLES         = 1
CONVECTIVE_TS_TYPE = "ADAMS_BASHFORTH"
CONVECTIVE_OP_TYPE = "CUI"
CONVECTIVE_FORM    = "ADVECTIVE"
NORMALIZE_PRESSURE = TRUE
VORTICITY_TAGGING  = FALSE
TAG_BUFFER         = 1
REGRID_INTERVAL    = 1000000
OUTPUT_U           = TRUE
OUTPUT_P           = TRUE
OUTPUT_F           = FALSE
OUTPUT_OMEGA       = TRUE
OUTPUT_DIV_U       = FALSE
OUTPUT_EE          = FALSE
ENABLE_LOGGING     = TRUE

// Perturbed profile to seed transition during spin-up.
U = "1.0 - (X_1 - 1.0)^2 + 0.08*sin(X_0)*sin(0.5*PI*X_1)*cos(2.0*X_2)"
V = "0.02*cos(2.0*X_0)*sin(PI*X_1)*sin(X_2)"
W = "-0.02*sin(X_0)*sin(PI*X_1)*cos(2.0*X_2)"
P = "0.0"

VelocityInitialConditions {
   function_0 = U
   function_1 = V
   function_2 = W
}

PressureInitialConditions {
   function = P
}

VelocityBcCoefs_0 {
   acoef_function_0 = "1.0"
   acoef_function_1 = "1.0"
   acoef_function_2 = "1.0"
   acoef_function_3 = "1.0"
   acoef_function_4 = "1.0"
   acoef_function_5 = "1.0"
   bcoef_function_0 = "0.0"
   bcoef_function_1 = "0.0"
   bcoef_function_2 = "0.0"
   bcoef_function_3 = "0.0"
   bcoef_function_4 = "0.0"
   bcoef_function_5 = "0.0"
   gcoef_function_0 = "0.0"
   gcoef_function_1 = "0.0"
   gcoef_function_2 = "0.0"
   gcoef_function_3 = "0.0"
   gcoef_function_4 = "0.0"
   gcoef_function_5 = "0.0"
}

